{
  "expo": {
    "name": "PowerLink",
    "slug": "powerlink",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1D1C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.powerlink.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Usado para tirar fotos de perfil e gravar vídeos de exercícios.",
        "NSMicrophoneUsageDescription": "Usado para gravar vídeos de exercícios.",
        "NSPhotoLibraryUsageDescription": "Usado para selecionar fotos de perfil e de avaliações físicas."
      }
    },
    "android": {
      "package": "com.powerlink.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1D1C"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-video",
      [
        "expo-image-picker",
        {
          "photosPermission": "Usado para selecionar fotos de perfil e de avaliações físicas.",
          "cameraPermission": "Usado para tirar fotos de perfil e gravar vídeos de exercícios.",
          "microphonePermission": "Usado para gravar vídeos de exercícios."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#8DC63F"
        }
      ]
    ]
  }
}
